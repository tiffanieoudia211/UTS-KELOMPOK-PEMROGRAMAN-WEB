<!DOCTYPE html>
<html lang="id">

<head>
    <title>Form Mahasiswa</title>

         <!-- ================= CSS Delviyany ================= -->
    <style>
        body{
            font-family:Arial;
            margin:0;
            padding:20px;
            background:#eef9e7;
            transition:.3s;
        }

        .container{
            max-width:800px;
            margin:auto;
        }

        h2{
            text-align:center;
        }

        form{
            background:#f7d2ed;
            padding:25px;
            border-radius:15px;
            margin-bottom:25px;
            box-shadow:0 8px 20px rgba(0,0,0,.2);
        }

        .row,.radio,.radio-group{
            display:flex;
            gap:10px;
        }

        .radio{
            justify-content:space-between;
            align-items:center;
            margin-bottom:15px;
        }

        .row input,
        .row select{
            flex:1;
        }

        input,textarea,select{
            width:100%;
            padding:10px;
            margin:5px 0 15px;
            border:none;
            border-radius:8px;
            outline:none;
            box-sizing:border-box;
        }

        button{
            padding:10px 15px;
            margin:5px 5px 0 0;
            border:none;
            border-radius:8px;
            cursor:pointer;
            font-weight:bold;
        }

        button:hover{
            opacity:.8;
        }

        .submit{background:green;color:white;}
        .reset{background:red;color:white;}
        .excel{background:#1d6f42;color:white;}
        .pdf{background:#c62828;color:white;}
        .mode{background:#333;color:white;}

        /* ================= CSS Syalosa (IKON AKSI)  ================= */
        .action-img{
            width:20px;
            cursor:pointer;
            margin:0 5px;
            transition:.2s;
        }

        .action-img:hover{
            transform:scale(1.2);
        }

        table{
            width:100%;
            border-collapse:collapse;
            background:white;
            border-radius:15px;
            overflow:hidden;
            box-shadow:0 8px 20px rgba(0,0,0,.2);
        }

        th{
            background:#333;
            color:white;
        }

        th,td{
            padding:10px;
            text-align:center;
        }

        /* ================= DARK MODE ================= */
        .dark-mode{
            background:#1e1e1e;
            color:white;
        }

        .dark-mode form,
        .dark-mode table{
            background:#2d2d2d;
            color:white;
        }

        .dark-mode input,
        .dark-mode textarea,
        .dark-mode select{
            background:#555;
            color:white;
        }

        .dark-mode th{
            background:#111;
        }
    </style>
<!-- ================= LIBRARY JAVASCRIPT : TIFFANI ================= -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
</head>

            <!-- ================= HTML : RYOMA ================= -->
<body>

<div class="container">

    <h2>Form Data Mahasiswa</h2>

    <form id="formMahasiswa">

        <div class="row">
            <input type="text" id="nim" placeholder="NIM" required>

            <input type="text" id="nama" placeholder="Nama" required>
        </div>

        <textarea id="alamat" placeholder="Alamat"></textarea>

        <div class="radio">

            <label>Jenis Kelamin:</label>

            <div class="radio-group">
                <label>
                    <input type="radio" name="jk" value="Pria">
                    Pria
                </label>

                <label>
                    <input type="radio" name="jk" value="Wanita">
                    Wanita
                </label>
            </div>

        </div>

        <div class="row">

            <label>Tanggal Lahir:</label>

            <select id="tanggal">
                <option value="">Tanggal</option>
            </select>

            <select id="bulan">
                <option value="">Bulan</option>
            </select>

            <select id="tahun">
                <option value="">Tahun</option>
            </select>

        </div>

        <input type="password" id="password" placeholder="Password">

        <button type="submit" class="submit" id="btnSubmit">
            Submit
        </button>

        <button type="reset" class="reset">
            Reset
        </button>

        <button type="button" class="excel" onclick="exportExcel()">
            Export Excel
        </button>

        <button type="button" class="pdf" onclick="exportPDF()">
            Export PDF
        </button>

        <button type="button" class="mode" onclick="toggleMode(this)">
            Dark Mode
        </button>

    </form>

    <h2>Data Mahasiswa</h2>

    <table id="tableMahasiswa">

        <thead>
            <tr>
                <th>NIM</th>
                <th>Nama</th>
                <th>Alamat</th>
                <th>JK</th>
                <th>TL</th>
                <th>Password</th>
                <th>Aksi</th>
            </tr>
        </thead>

        <tbody id="tableBody"></tbody>

    </table>

</div>

<!-- ================= JAVASCRIPT Tiffani ================= -->
<script>

const form = document.getElementById("formMahasiswa");
const tableBody = document.getElementById("tableBody");
const btnSubmit = document.getElementById("btnSubmit");

const nimInput = document.getElementById("nim");
const namaInput = document.getElementById("nama");
const alamatInput = document.getElementById("alamat");
const passwordInput = document.getElementById("password");

const tanggal = document.getElementById("tanggal");
const bulan = document.getElementById("bulan");
const tahun = document.getElementById("tahun");

let editRow = null;
let dark = false;

/* ================= DROPDOWN TANGGAL ================= */
for(let i=1;i<=31;i++){

    let val = i.toString().padStart(2,"0");

    tanggal.innerHTML += `
        <option value="${val}">
            ${val}
        </option>
    `;
}

/* ================= DROPDOWN BULAN ================= */
[
"Januari","Februari","Maret","April","Mei","Juni",
"Juli","Agustus","September","Oktober","November","Desember"

].forEach((b,i)=>{

    bulan.innerHTML += `
        <option value="${(i+1).toString().padStart(2,"0")}">
            ${b}
        </option>
    `;
});

/* ================= DROPDOWN TAHUN ================= */
for(let i=1980;i<=2026;i++){

    tahun.innerHTML += `
        <option value="${i}">
            ${i}
        </option>
    `;
}

/* ================= SUBMIT ================= */
form.addEventListener("submit",function(e){

    e.preventDefault();

    const nim = nimInput.value;
    const nama = namaInput.value;
    const alamat = alamatInput.value;
    const password = passwordInput.value;

    if(password.length < 8){

        alert("Password minimal 8 karakter!");
        return;
    }

    const jk = document.querySelector('input[name="jk"]:checked');

    const jenisKelamin = jk ? jk.value : "-";

    const tl = `${tanggal.value}-${bulan.value}-${tahun.value}`;

    const passwordTampil = "*".repeat(password.length);

    /* ================= MODE EDIT ================= */
    if(editRow){

        editRow.cells[0].innerText = nim;
        editRow.cells[1].innerText = nama;
        editRow.cells[2].innerText = alamat;
        editRow.cells[3].innerText = jenisKelamin;
        editRow.cells[4].innerText = tl;
        editRow.cells[5].innerText = passwordTampil;

        editRow = null;

        btnSubmit.innerText = "Submit";

    }else{

        /* ================= TAMBAH DATA ================= */
        const row = document.createElement("tr");

        row.innerHTML = `
            <td>${nim}</td>
            <td>${nama}</td>
            <td>${alamat}</td>
            <td>${jenisKelamin}</td>
            <td>${tl}</td>
            <td>${passwordTampil}</td>

            <td>

                <img src="https://cdn-icons-png.flaticon.com/512/5935/5935145.png"
                     class="action-img"
                     onclick="editData(this)">

                <img src="https://cdn-icons-png.flaticon.com/512/6861/6861362.png"
                     class="action-img"
                     onclick="hapusData(this)">

            </td>
        `;

        tableBody.appendChild(row);
    }

    form.reset();
});

/* ================= HAPUS DATA ================= */
function hapusData(btn){

    if(confirm("Yakin ingin menghapus data?")){

        btn.parentElement.parentElement.remove();
    }
}

/* ================= EDIT DATA ================= */
function editData(btn){

    editRow = btn.parentElement.parentElement;

    nimInput.value = editRow.cells[0].innerText;
    namaInput.value = editRow.cells[1].innerText;
    alamatInput.value = editRow.cells[2].innerText;

    const jkValue = editRow.cells[3].innerText;

    document.querySelectorAll('input[name="jk"]').forEach(r=>{

        r.checked = (r.value === jkValue);
    });

    const ttl = editRow.cells[4].innerText.split("-");

    tanggal.value = ttl[0];
    bulan.value = ttl[1];
    tahun.value = ttl[2];

    btnSubmit.innerText = "Update";
}

/* ================= EXPORT EXCEL ================= */
function exportExcel(){

    let wb = XLSX.utils.table_to_book(
        document.getElementById("tableMahasiswa"),
        {sheet:"Data Mahasiswa"}
    );

    XLSX.writeFile(wb,"DataMahasiswa.xlsx");
}

/* ================= EXPORT PDF ================= */
function exportPDF(){

    const { jsPDF } = window.jspdf;

    let doc = new jsPDF();

    doc.text("Data Mahasiswa",14,15);

    doc.autoTable({
        html:"#tableMahasiswa",
        startY:20
    });

    doc.save("DataMahasiswa.pdf");
}

/* ================= DARK MODE ================= */
function toggleMode(btn){

    document.body.classList.toggle("dark-mode");

    dark = !dark;

    btn.innerText = dark ? "Light Mode" : "Dark Mode";
}

</script>

</body>
</html>
